#' @title param_1_new_2_var
#' @description Test function that assigns new variable to the sum of two existing variables. The names of the two existing variables and the new variable are specified by parameters.
#' @param in_variable1 `character` Name of the input variable 1
#' @param in_variable2 `character` Name of the input variable 2
#' @param new_variable `character` Name of the output variable
#' @type derivation
#' @depends ADLB {{in_variable1}}
#' @depends ADLB {{in_variable2}}
#' @outputs {{new_variable}}

ADLB <- ADLB |>
  dplyr::mutate({{new_variable}} = {{in_variable1}} + {{in_variable2}})
