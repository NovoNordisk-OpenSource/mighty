#' @title param_var2_2_var
#' @description Test function that assigns new variable to the sum of two existing variables. The names of the two existing variables are specified by parameters.
#' @param in_variable1 `character` Name of the input variable 1
#' @param in_variable2 `character` Name of the input variable 2
#' @type derivation
#' @depends ADLB {{in_variable1}}
#' @depends ADLB {{in_variable2}}
#' @outputs PARAM_VAR2

ADLB <- ADLB |>
  dplyr::mutate(PARAM_VAR2 = {{in_variable1}} + {{in_variable2}})
