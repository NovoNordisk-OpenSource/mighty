{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ADaM Specifications Schema",
  "description": "Schema for validating ADaM domain specifications YAML files",
  "type": "object",
  "required": [
    "table",
    "init",
    "column_action"
  ],
  "additionalProperties": false,
  "properties": {
    "table": {
      "$ref": "#/$defs/table"
    },
    "init": {
      "$ref": "#/$defs/init"
    },
    "column_action": {
      "$ref": "#/$defs/column_action"
    },
    "row_action": {
      "$ref": "#/$defs/row_action"
    }
  },
  "$defs": {
    "table": {
      "type": "object",
      "description": "Basic table information",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the table (e.g., ADLB, ADSL)",
          "minLength": 1
        }
      }
    },
    "init": {
      "type": "object",
      "description": "Initialization configuration for the ADaM table",
      "required": [
        "base_domains",
        "filter_domain",
        "filter_global",
        "filter_depend_cols"
      ],
      "additionalProperties": false,
      "properties": {
        "base_domains": {
          "type": "array",
          "description": "Array of base domains",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$",
            "minLength": 1
          }
        },
        "filter_domain": {
          "type": "array",
          "description": "Domain filters",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
              "^[a-zA-Z_][a-zA-Z0-9_]*$": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            }
          }
        },
        "filter_global": {
          "type": "array",
          "description": "Global filter expressions",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "filter_depend_cols": {
          "type": "array",
          "description": "Columns that filters depend on",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "column_action": {
      "type": [
        "object"
      ],
      "description": "Map of column name to metadata",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": {
          "$ref": "#/$defs/column_props"
        }
      }
    },
    "column_props": {
      "type": [
        "object",
        "null"
      ],
      "description": "Metadata for a single column",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Source column (e.g., ADSL.AGE)",
          "minLength": 1
        },
        "code_id": {
          "type": "string",
          "description": "Standard component or path to R function file",
          "minLength": 1
        },
        "parameters": {
          "$ref": "#/$defs/parameters_array"
        },
        "depend_rows": {
          "$ref": "#/$defs/depend_rows_array"
        }
      }
    },
    "row_action": {
      "type": "object",
      "description": "Map of row action id -> row action item",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": {
          "$ref": "#/$defs/row_action_item"
        }
      }
    },
    "row_action_item": {
      "type": ["object"],
      "required": [
        "code_id"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "code_id": {
          "type": "string"
        },
        "depend_rows": {
          "$ref": "#/$defs/depend_rows_array"
        },
        "parameters": {
          "$ref": "#/$defs/parameters_array"
        }
      }
    },
    "parameters_array": {
      "type": "array",
      "description": "Array of parameters to pass to standard components",
      "items": {
        "type": "object",
        "description": "Parameter key-value pair",
        "minProperties": 1,
        "additionalProperties": {
          "type": [
            "string",
            "number",
            "boolean",
            "integer"
          ],
          "description": "Parameter value"
        }
      }
    },
    "depend_rows_array": {
      "type": "array",
      "description": "Unique identifier for the row action the current row action depends upon",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
